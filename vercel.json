{
  "$schema": "https://vercel.com/schema.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "handle": "filesystem" },
    { "source": "/api/:path*", "destination": "/api" },
    {
      "source": "/(?!api(?:/|$))(.*)",
      "destination": "/index.html"
    }
  ]
}
