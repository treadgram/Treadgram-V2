# Required for auth sessions (use a long random string in production)
JWT_SECRET=

# PostgreSQL connection string (Drizzle uses postgres dialect)
DATABASE_URL=

# Optional: Manus / OAuth flows
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=

# Owner system console at /system/login (set both to enable)
# SYSTEM_ADMIN_EMAIL=
# SYSTEM_ADMIN_PASSWORD=
# Optional stable openId for the owner row in DB (default: owner_system_console)
# SYSTEM_OWNER_OPEN_ID=

# Server (defaults shown)
# PORT=3000
# HOST=0.0.0.0

# Optional: Umami analytics (set at build time for Vite if you use them)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
